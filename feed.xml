---
layout: null
permalink: /feed.xml
---
<?xml version="1.0" encoding="UTF-8"?>
{% assign tech_posts = site.posts | where_exp:"post","post.path contains '_posts/'" %}
{% assign note_posts = site.note | sort: "date" | reverse %}
{% assign all_posts = tech_posts | concat: note_posts | sort: "date" | reverse %}
<rss version="2.0">
  <channel>
    <title>{{ site.title }}</title>
    <link>{{ site.url }}</link>
    <description>{{ site.description }}</description>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>

    {% for post in all_posts limit:30 %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <link>{{ site.url }}{{ post.url }}</link>
      <guid>{{ site.url }}{{ post.url }}</guid>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      <description><![CDATA[
{{ post.excerpt | strip_html | truncate: 500 }}
]]></description>
      <content:encoded><![CDATA[
{{ post.content }}
]]></content:encoded>
    </item>
    {% endfor %}

  </channel>
</rss>