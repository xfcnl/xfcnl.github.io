$player-bg = #161b22
$player-border = rgba(148, 163, 184, 0.2)
$accent = #58a6ff
$text-secondary = #8b949e

// ===== 播放器容器 =====
#music-player-container
  position fixed
  left 16px
  top 120px
  z-index 2000
  max-width 320px
  transition transform 0.25s ease, width 0.25s ease, left 0.25s ease
  -webkit-transition transform 0.25s ease, width 0.25s ease, left 0.25s ease

  // ===== 吸附状态 =====
  &.docked
    width 56px
    max-width 56px
    transform translateX(-40px)
    overflow visible

    .aplayer
      width 56px
      height 56px
      border-radius 8px

      .aplayer-info,
      .aplayer-control,
      .aplayer-list
        display none

      .aplayer-pic
        width 48px
        height 48px
        margin 4px
        border-radius 6px

  // ===== 播放器主体 =====
  .aplayer
    position static
    bottom auto
    right auto
    background-color $player-bg
    border 1px solid $player-border
    border-radius 8px
    box-shadow 0 4px 16px rgba(0, 0, 0, 0.5)
    font-family -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans", Helvetica, Arial, sans-serif

    // ===== 播放器信息 =====
    .aplayer-info
      background linear-gradient(135deg, $player-bg 0%, #0d1117 100%)

      .aplayer-music
        .aplayer-title
          color #e6edf3

        .aplayer-author
          color $text-secondary

      .aplayer-lrc
        p
          color $text-secondary

        .aplayer-lrc-current
          color $accent

    // ===== 播放器控制栏 =====
    .aplayer-control
      background-color $player-bg
      border-top 1px solid $player-border

      .aplayer-button
        color $text-secondary

        &:hover
          color $accent

      .aplayer-time
        color $text-secondary

    // ===== 进度条 =====
    .aplayer-bar-wrap
      .aplayer-bar
        background-color rgba($accent, 0.2)

      .aplayer-played
        background-color $accent

    // ===== 音量 =====
    .aplayer-volume-wrap
      .aplayer-volume-bar-wrap
        .aplayer-volume-bar
          background-color rgba($accent, 0.2)

        .aplayer-volume-fill
          background-color $accent

    // ===== 播放列表 =====
    .aplayer-list
      background-color #0d1117
      border-top 1px solid $player-border

      li
        border-bottom 1px solid rgba(148, 163, 184, 0.1)
        color $text-secondary
        transition all 0.3s ease

        &:hover
          background-color $player-bg
          color $accent

        &.aplayer-list-light
          background-color $player-bg
          color $accent

        .aplayer-list-cur
          color $accent

    // ===== 迷你模式 =====
    &.aplayer-mini
      width 320px
      height 60px

      .aplayer-info
        display none

      .aplayer-control
        height 60px
        display flex
        align-items center
        justify-content space-between
        padding 0 12px

      .aplayer-button
        margin 0 4px

  // ===== 响应式 =====
  @media (max-width: 1200px)
    left 8px
    right auto
    max-width 300px

  @media (max-width: 768px)
    position fixed
    bottom 80px
    left auto
    right 8px
    top auto
    max-width 280px

    .aplayer
      max-width 280px

      &.aplayer-mini
        width 280px
